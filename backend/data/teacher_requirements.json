"Fine & Gross Motor Skill Development",
"Classroom management for early learners",
"Parent communication & counseling"
],
"preferred_experience": [
"1–3 years in pre-primary/kindergarten",
"Experience with NCERT 'Jadui Pitara' or Montessori methods"
]
},
