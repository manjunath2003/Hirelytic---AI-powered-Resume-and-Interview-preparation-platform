{
"Pre-Primary (Nursery-KG)": {
"required_qualifications": [
"Senior Secondary (10+2) with minimum 50% marks",
"Mandatory Diploma in Nursery Teacher Education / Pre-School Education / ECCE (min. 2 years)",
"OR B.Ed. (Nursery) from NCTE recognized institution"
],
"core_skills": [
"Play-based and Toy-based Pedagogy (NEP 2020 compliant)",
"Foundational Literacy and Numeracy (FLN) readiness",
"Storytelling, Rhymes, and Puppetry",
